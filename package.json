{
  "name": "cynapx",
  "version": "1.0.0",
  "description": "Cynapx: High-Performance Isolated Code Knowledge Engine for AI Agents",
  "main": "dist/bootstrap.js",
  "bin": {
    "cynapx": "dist/bootstrap.js"
  },
  "license": "MIT",
  "scripts": {
    "start": "ts-node src/bootstrap.ts",
    "build": "npm run build:ts && npm run build:copy",
    "build:ts": "tsc",
    "build:copy": "powershell -NoProfile -Command \"Copy-Item -Path 'src/indexer/languages/queries' -Destination 'dist/indexer/languages/' -Recurse -Force ; If (Test-Path 'src-native/*.node') { Copy-Item -Path 'src-native/*.node' -Destination 'dist/' -Force }\"",
    "build:native": "npm run build --prefix src-native",
    "dev": "ts-node-dev --respawn src/bootstrap.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "express": "^4.19.2",
    "ignore": "^7.0.5",
    "simple-git": "^3.30.0",
    "sqlite-vec": "^0.1.7-alpha.2",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-gdscript": "^6.1.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^5.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/chokidar": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  },
  "overrides": {
    "tree-sitter": "^0.25.0",
    "tree-sitter-c-sharp": {
      "tree-sitter": "^0.25.0"
    },
    "tree-sitter-cpp": {
      "tree-sitter": "^0.25.0"
    },
    "tree-sitter-java": {
      "tree-sitter": "^0.25.0"
    },
    "tree-sitter-kotlin": {
      "tree-sitter": "^0.25.0"
    },
    "tree-sitter-typescript": {
      "tree-sitter": "^0.25.0"
    }
  }
}
