{
  "name": "cynapx",
  "version": "3.0.0",
  "description": "Cynapx: High-Performance Isolated Code Knowledge Engine for AI Agents",
  "main": "dist/bootstrap.js",
  "bin": {
    "cynapx": "dist/bootstrap.js",
    "cynapx-admin": "dist/cli/admin.js"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "ts-node src/bootstrap.ts",
    "build": "npm run build:ts && npm run build:copy",
    "build:ts": "tsc",
    "build:copy": "node scripts/build-copy.js",
    "build:native": "npm run build --prefix src-native",
    "dev": "ts-node-dev --respawn src/bootstrap.ts",
    "prepack": "npm run build",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench",
    "admin": "ts-node src/cli/admin.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/swagger-ui-express": "^4.1.8",
    "better-sqlite3": "^12.0.0",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "ignore": "^7.0.5",
    "js-yaml": "^4.2.0",
    "simple-git": "^3.30.0",
    "sqlite-vec": "^0.1.9",
    "swagger-ui-express": "^5.0.1",
    "tree-sitter": "^0.25.0",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-gdscript": "^6.1.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^5.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/chokidar": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "tree-sitter": "^0.25.0",
    "fast-uri": "^3.1.2",
    "qs": "^6.15.2",
    "hono": "^4.12.21",
    "postcss": "^8.5.10"
  }
}
